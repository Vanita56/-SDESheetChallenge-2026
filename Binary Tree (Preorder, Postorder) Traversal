postorder Traversal

class Solution {
     List<Integer>ans=new ArrayList<>();
    private void traverse(TreeNode root){
        if(root==null){ return ;}
        traverse(root.left);
        traverse(root.right);
        ans.add(root.val);
    }
    public List<Integer> postorderTraversal(TreeNode root) {
        traverse(root);
        return ans;
    }
}
