Preorder Traversal

//Space Complexity O(N) Time C O(N)
class Solution {
    List<Integer>ans=new ArrayList<>();
    private void traverse(TreeNode root){
        if(root==null){ return ;}
        ans.add(root.val);
        traverse(root.left);
        traverse(root.right);
    }
    public List<Integer> preorderTraversal(TreeNode root) {
        traverse(root);
        return ans;
    }
}
